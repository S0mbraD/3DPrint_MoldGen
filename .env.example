# MoldGen 环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# === 服务器配置 ===
MOLDGEN_HOST=127.0.0.1
MOLDGEN_PORT=8000
MOLDGEN_DEBUG=false

# === AI API Keys ===
# DeepSeek (主力聊天/Agent, 兼容 OpenAI SDK)
MOLDGEN_AI_DEEPSEEK_API_KEY=sk-your-deepseek-key

# 通义千问 (多模态视觉+聊天, 兼容 OpenAI SDK)
MOLDGEN_AI_QWEN_API_KEY=sk-your-qwen-key

# Kimi / Moonshot (备选聊天)
MOLDGEN_AI_KIMI_API_KEY=sk-your-kimi-key

# 通义万相 (图像生成)
MOLDGEN_AI_WANXIANG_API_KEY=sk-your-wanxiang-key

# Tripo3D (3D模型生成)
MOLDGEN_AI_TRIPO_API_KEY=tsk_your-tripo-key
